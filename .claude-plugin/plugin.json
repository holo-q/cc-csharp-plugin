{
  "name": "cc-csharp-lsp",
  "version": "0.1.0",
  "description": "C# language server using csharp-ls - Roslyn-based LSP",
  "author": {
    "name": "holo-q"
  },
  "repository": "https://github.com/razzmatazz/csharp-language-server",
  "license": "MIT",
  "keywords": ["csharp", "dotnet", "lsp", "language-server", "roslyn", "csharp-ls"],
  "lspServers": {
    "csharp-ls": {
      "command": "csharp-ls",
      "args": [],
      "extensionToLanguage": {
        ".cs": "csharp"
      }
    }
  },
  "mcpServers": {
    "csharp-ls": {
      "command": "uvx",
      "args": ["--refresh", "--from", "git+https://github.com/holo-q/cc-lsp-now", "cc-lsp-now", "csharp"],
      "env": {
        "LSP_SERVERS": "csharp-ls",
        "LSP_PROJECT_MARKERS": "*.sln,*.csproj,Directory.Build.props,global.json,.git",
        "LSP_WARMUP_PATTERNS": "*.cs",
        "LSP_WARMUP_EXCLUDE": "bin,obj,packages,.vs,node_modules",
        "LSP_LANGUAGE": "csharp"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "LSP",
        "hooks": [
          {
            "type": "command",
            "command": "uvx --refresh --from git+https://github.com/holo-q/cc-lsp-now cc-lsp-now-redirect-hook csharp"
          }
        ]
      }
    ]
  }
}
